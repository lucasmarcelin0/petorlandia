{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Flask dev server",
      "runtimeExecutable": "python",
      "runtimeArgs": ["app.py"],
      "port": 5000
    },
    {
      "name": "Flask dev server (flask run)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "flask", "run", "--port", "5001"],
      "port": 5001
    },
    {
      "name": "Scheduler",
      "runtimeExecutable": "python",
      "runtimeArgs": ["scheduler.py"],
      "port": null
    }
  ]
}
