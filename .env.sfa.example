# ============================================================
# Variáveis de ambiente — módulo SFA (Síndromes Febris Agudas)
# Copie para .env e preencha os valores em branco
# ============================================================

# --- Pesquisador responsável ---
SFA_NOME_PESQUISADOR=Lucas
SFA_EMAIL_PESQUISADOR=lukemarki3@gmail.com

# --- Telefonia (padrão Orlândia) ---
SFA_DDD_PADRAO=16
SFA_PREFIXO_PAIS=55

# --- Prazos de seguimento (dias) ---
SFA_DIAS_T10=10
SFA_DIAS_T30=30
SFA_DIAS_LEMBRETE=2
SFA_DIAS_SEM_T0_ALERTA=5
SFA_TOLERANCIA_ALERTA_DIAS=1

# --- Planilha SINAN no Google Sheets ---
SFA_SHEET_ID_SINAN=15UdUxNhuL3VUNpJr_iEiiWTVM-rlKtVcGPeY9jSFJ_E
SFA_SHEET_RANGE_SINAN=A:T
# Opcional: nome exato da aba ou gid da aba quando a planilha tiver múltiplas abas
# SFA_SHEET_TITLE_SINAN=SINAN
# SFA_SHEET_GID_SINAN=0

# --- IDs dos Google Forms ---
SFA_FORM_T0_ID=1PbQj5rF4OkeNOYN44rCoVbbDYE-GftwHn-BNGC3-kmg
SFA_FORM_T10_ID=1v8WL_3ecBUDU2N3CDDQeCULvwYI3UHCjA950aFwQj3g
SFA_FORM_T30_ID=1VFrH7aFkjetu0Xu7lA6ch9ffqArExLNpt8933rsWyjw

# Links diretos dos formulários (gerados automaticamente a partir dos IDs acima se não definidos)
# SFA_LINK_FORM_T10=https://docs.google.com/forms/d/1v8WL_3ecBUDU2N3CDDQeCULvwYI3UHCjA950aFwQj3g/viewform
# SFA_LINK_FORM_T30=https://docs.google.com/forms/d/1VFrH7aFkjetu0Xu7lA6ch9ffqArExLNpt8933rsWyjw/viewform

# Planilha de respostas do T0 (aceita ID ou URL completa com gid)
# SFA_T0_RESPONSE_SHEET=https://docs.google.com/spreadsheets/d/.../edit#gid=...
# SFA_T0_RESPONSE_RANGE=A:ZZ
# Opcional: nome exato da aba ou gid
# SFA_T0_RESPONSE_TITLE=Respostas ao formulário 1
# SFA_T0_RESPONSE_GID=0
# Polling automático local/em produção
# Caminhos dos schemas dos formularios nativos
SFA_T0_FORM_SCHEMA_FILE=config/sfa_t0_form.json
SFA_T10_FORM_SCHEMA_FILE=config/sfa_t10_form.json
SFA_T30_FORM_SCHEMA_FILE=config/sfa_t30_form.json
SFA_AUTO_SYNC_MINUTES=0

# --- Entry IDs de pré-preenchimento (formulário T0) ---
# Extraídos via forceCorrectIds() no GAS ou inspecionando os URLs do Forms
SFA_ENTRY_T0_ID_ESTUDO=entry.1447355807
SFA_ENTRY_T0_FICHA_SINAN=
SFA_ENTRY_T0_NOME=entry.2001573769
SFA_ENTRY_T0_DATA_NASC_BASE=entry.1487617078
# Opcional, mas recomendado para identificar a resposta pelo link unico enviado ao paciente
SFA_ENTRY_T0_TOKEN=

# --- Entry IDs de pré-preenchimento (formulários T10 e T30) ---
SFA_ENTRY_T10_NOME=entry.1342379317
SFA_ENTRY_T30_NOME=entry.937246935
# Os entry IDs de id_estudo para T10/T30 precisam ser descobertos rodando
# salvarEntryIdsAcompanhamentos() no GAS e depois definidos abaixo:
SFA_ENTRY_T10_ID_ESTUDO=
SFA_ENTRY_T30_ID_ESTUDO=

# --- URL base do Flask (usada fora do contexto de requisição, ex: APScheduler) ---
SFA_WEBAPP_URL=https://seu-dominio.com

# --- Segurança ---
# Token de admin para rotas POST (/sfa/sync, /sfa/rotina)
# Em produção, as telas internas do SFA ficam fechadas por padrão.
# Você pode acessar via login de usuário admin do sistema ou com este token.
SFA_ADMIN_TOKEN=

# Segredo compartilhado para webhooks do Google Apps Script
# Obrigatório fora de teste/desenvolvimento automatizado.
# Configurar o mesmo valor em SFA_WEBHOOK_SECRET= no .gs
SFA_WEBHOOK_SECRET=

# Somente para desenvolvimento local temporário.
# Mantém as telas internas abertas sem login/token, como o comportamento legado.
# Nunca habilite em produção.
SFA_ALLOW_OPEN_ACCESS=0

# --- Credenciais Google (conta de serviço para leitura do SINAN) ---
# Opção 1: JSON em linha (útil para ambientes de nuvem com env vars)
# SFA_GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
# Opção 2: caminho para o arquivo JSON no servidor
SFA_GOOGLE_CREDENTIALS_FILE=/caminho/para/service-account.json
# Se houver um unico JSON de service account na raiz do projeto, a aplicacao tenta detecta-lo automaticamente.
