{
  "title": "T10 Estudo SFA Orlandia",
  "subtitle": "Acompanhamento de 10 dias apos a primeira entrevista. Apenas 15 perguntas rapidas sobre sua evolucao.",
  "submit_label": "Enviar acompanhamento T10",
  "sections": [
    {
      "title": "Secao 1: Identificacao",
      "description": "Dados para vincular esta resposta ao seu registro inicial.",
      "fields": [
        {
          "key": "cpf",
          "label": "CPF",
          "type": "text",
          "required": false,
          "prefill": "cpf",
          "placeholder": "Digite apenas numeros"
        },
        {
          "key": "nome",
          "label": "2. Nome completo (confirmacao)",
          "type": "text",
          "required": false,
          "prefill": "nome"
        },
        {
          "key": "data_entrevista_t10",
          "label": "3. Data desta entrevista (T10)",
          "type": "date",
          "required": true
        }
      ]
    },
    {
      "title": "Secao 2: Evolucao da sua saude",
      "description": "Como voce esta se sentindo 10 dias apos a primeira entrevista?",
      "fields": [
        {
          "key": "classificacao_melhora",
          "label": "4. Como classifica sua melhora desde a primeira entrevista?",
          "type": "radio",
          "required": true,
          "options": [
            "Curado(a) - Sem sintomas, retomei atividades normais",
            "Melhorando - Sintomas leves, em recuperacao",
            "Estacionado(a) - Nem piorou, nem melhorou",
            "Piorando - Sintomas persistem ou pioraram",
            "Recaida - Melhorei e piorou novamente"
          ]
        },
        {
          "key": "sintomas_persistentes",
          "label": "5. Quais sintomas ainda persistem? (marque todos)",
          "type": "checkboxes",
          "required": true,
          "options": [
            "Febre",
            "Dores articulares (juntas)",
            "Dores musculares",
            "Cansaco extremo/fadiga",
            "Manchas vermelhas na pele",
            "Coceira",
            "Dor de cabeca",
            "Nausea/tontura",
            "Falta de ar",
            "Outro"
          ]
        },
        {
          "key": "sintomas_persistentes_outro",
          "label": "Se marcou outro sintoma, qual?",
          "type": "text",
          "required": false
        },
        {
          "key": "dor_articulacoes_impacto",
          "label": "6. A dor nas articulacoes ainda impede atividades diarias?",
          "type": "radio",
          "required": true,
          "options": [
            "Nao tenho mais dor articular",
            "Sim, totalmente impedido(a) de realizar atividades",
            "Sim, parcialmente impedido(a)",
            "Sinto dor, mas nao impede minhas atividades",
            "Tenho dor apenas ao realizar esforcos"
          ]
        },
        {
          "key": "retornou_servico_saude",
          "label": "7. Precisou retornar a algum servico de saude apos a primeira consulta?",
          "type": "radio",
          "required": true,
          "options": [
            "Nao",
            "Sim"
          ]
        },
        {
          "key": "quantas_vezes_retornou",
          "label": "Quantas vezes retornou?",
          "type": "number",
          "required": false,
          "min": 0,
          "step": 1,
          "help_text": "Se nao retornou, deixe em branco ou informe 0."
        },
        {
          "key": "motivo_retorno_servico",
          "label": "Por qual motivo? (marque todos)",
          "type": "checkboxes",
          "required": false,
          "options": [
            "Piora dos sintomas",
            "Consulta de retorno/monitoramento",
            "Realizacao de exames",
            "Receber resultados",
            "Buscar segunda opiniao",
            "Outro"
          ]
        },
        {
          "key": "motivo_retorno_servico_outro",
          "label": "Se marcou outro motivo, qual?",
          "type": "text",
          "required": false
        },
        {
          "key": "internacao_t10",
          "label": "8. Foi internado(a) ou hospitalizado(a)?",
          "type": "radio",
          "required": true,
          "options": [
            "Nao",
            "Sim"
          ]
        },
        {
          "key": "dias_internado_t10",
          "label": "Por quantos dias?",
          "type": "number",
          "required": false,
          "min": 0,
          "step": 1
        },
        {
          "key": "local_internacao_t10",
          "label": "Onde foi internado(a)?",
          "type": "radio",
          "required": false,
          "options": [
            "Hospital publico",
            "Hospital particular",
            "Ambos"
          ]
        },
        {
          "key": "diagnostico_definitivo",
          "label": "9. Recebeu algum diagnostico definitivo de profissional de saude?",
          "type": "radio",
          "required": true,
          "options": [
            "Nao, ainda nao sei o que tenho",
            "Sim, recebi diagnostico (qual?)",
            "Fiz exames mas ainda nao recebi resultado",
            "Recebi resultado mas nao entendi/me explicaram"
          ]
        },
        {
          "key": "diagnostico_informado",
          "label": "Se recebeu diagnostico, qual foi informado?",
          "type": "text",
          "required": false
        }
      ]
    },
    {
      "title": "Secao 3: Impacto acumulado",
      "description": "Impacto total da doenca ate o momento.",
      "fields": [
        {
          "key": "dias_incap_novos",
          "label": "10. Total de dias completamente incapacitado (desde o inicio)",
          "type": "number",
          "required": true,
          "min": 0,
          "step": 1,
          "help_text": "Soma de todos os dias que nao pode trabalhar ou estudar, incluindo os ja informados antes."
        },
        {
          "key": "ausencia_familiar",
          "label": "11. Alguem da familia ainda precisa se ausentar para cuidar de voce?",
          "type": "radio",
          "required": true,
          "options": [
            "Nao, ninguem mais precisa faltar",
            "Sim, ainda faltam alguns dias por semana",
            "Nao, mas alguem reduziu carga horaria",
            "Sim, precisamos de cuidador profissional"
          ]
        }
      ]
    },
    {
      "title": "Secao 4: Gastos totais ate hoje",
      "description": "Preencha os valores acumulados ate o momento.",
      "fields": [
        {
          "key": "custo_remedios",
          "label": "12a. Medicamentos (R$)",
          "type": "number",
          "required": true,
          "min": 0,
          "step": 0.01,
          "help_text": "Valor total gasto com remedios."
        },
        {
          "key": "custo_consultas",
          "label": "12b. Consultas e exames (R$)",
          "type": "number",
          "required": true,
          "min": 0,
          "step": 0.01
        },
        {
          "key": "custo_transporte",
          "label": "12c. Transporte para atendimento (R$)",
          "type": "number",
          "required": true,
          "min": 0,
          "step": 0.01
        },
        {
          "key": "custo_outros",
          "label": "12d. Outros gastos (R$)",
          "type": "number",
          "required": false,
          "min": 0,
          "step": 0.01,
          "help_text": "Alimentacao especial, produtos medicos e outros gastos relacionados."
        },
        {
          "key": "renda_familiar_afetada",
          "label": "13. Sua renda familiar foi significativamente afetada?",
          "type": "radio",
          "required": true,
          "options": [
            "Nao, recebo/ganho normalmente",
            "Sim, reducao temporaria da renda",
            "Sim, perdi o emprego/trabalho temporariamente",
            "Sim, precisei usar economias/reservas",
            "Sim, outros impactos financeiros"
          ]
        }
      ]
    },
    {
      "title": "Secao 5: Perspectiva e observacoes",
      "description": "Ultimas perguntas sobre sua recuperacao neste ponto do acompanhamento.",
      "fields": [
        {
          "key": "retorno_atividades_previsao",
          "label": "14. Quando acha que conseguira retomar 100% das atividades?",
          "type": "radio",
          "required": true,
          "options": [
            "Ja retomei todas as atividades",
            "Em 1 semana ou menos",
            "Em 2-4 semanas",
            "Mais de 1 mes",
            "Nao consigo prever",
            "Acho que terei limitacoes permanentes"
          ]
        },
        {
          "key": "observacoes_finais",
          "label": "15. Observacoes importantes sobre sua evolucao:",
          "type": "textarea",
          "required": false,
          "help_text": "Conte algo que nao perguntamos, alguma preocupacao, ou algo importante sobre sua recuperacao."
        }
      ]
    }
  ]
}
